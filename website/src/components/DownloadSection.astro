---

<section id="download" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Download LangHire</h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Free and open source. Requires an LLM API key (OpenAI, Anthropic, or AWS Bedrock).
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {platforms.map(platform => (
        <div class="card text-center hover:shadow-md transition-shadow">
          <div class={`inline-flex mb-4 ${platform.color}`}>
            <Fragment set:html={platform.icon} />
          </div>
          <h3 class="text-lg font-bold mb-4">{platform.name}</h3>
          <div class="space-y-2">
            {platform.links.map(link => (
              <a
                href={link.href}
                class={link.primary ? 'btn-primary w-full text-xs' : 'btn-secondary w-full text-xs'}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-xs text-muted-foreground mt-8 max-w-lg mx-auto">
      The binaries are not code-signed. Your OS may show a security warning on first launch &mdash;
      see the <a href="https://github.com/jaimaann/LangHire#installation-notes" class="text-primary hover:underline">installation notes</a> for instructions.
    </p>
  </div>
</section>
