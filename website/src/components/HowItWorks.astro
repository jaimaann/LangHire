---
const steps = [
  {
    number: '1',
    title: 'Collect',
    description: 'An AI browser agent logs into LinkedIn, searches for jobs matching your target titles and locations, and saves each listing.',
    icon: '<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>',
    color: 'bg-blue-50 text-blue-600',
  },
  {
    number: '2',
    title: 'Apply',
    description: 'For each job, the agent opens the application, fills every field using your profile, uploads your resume, answers screening questions, and submits.',
    icon: '<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>',
    color: 'bg-primary/10 text-primary',
  },
  {
    number: '3',
    title: 'Learn',
    description: 'After each application, the system extracts procedural learnings &mdash; navigation patterns, form strategies, and UI quirks &mdash; stored per ATS domain.',
    icon: '<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3 4 4.5 4.5 0 0 1-3-4"/><path d="M12 18v4"/></svg>',
    color: 'bg-purple-50 text-purple-600',
  },
];
---

<section id="how-it-works" class="py-20 md:py-28 bg-secondary">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">How It Works</h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        A three-stage loop: Collect, Apply, Learn. Each cycle makes the next one faster.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step, i) => (
        <div class="relative text-center">
          <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-6 ${step.color}`}>
            <Fragment set:html={step.icon} />
          </div>
          <h3 class="text-xl font-bold mb-3">{step.title}</h3>
          <p class="text-muted-foreground leading-relaxed" set:html={step.description}></p>
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 -right-4 w-8 text-border">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
