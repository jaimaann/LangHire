---
const navLinks = [
  { href: '/#features', label: 'Features' },
  { href: '/#how-it-works', label: 'How It Works' },
  { href: '/blog', label: 'Blog' },
  { href: '/#download', label: 'Download' },
];
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-border/50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-3">
      <img src="/icon.png" alt="" width="32" height="32" class="rounded-lg" />
      <span class="text-lg font-bold text-foreground">LangHire</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/jaimaann/LangHire"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors"
        aria-label="View on GitHub"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a href="/#download" class="btn-primary text-xs px-4 py-2">
        Download
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      class="md:hidden p-2 text-foreground"
      aria-label="Toggle menu"
      aria-expanded="false"
      id="mobile-menu-btn"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-white px-6 py-4">
    {navLinks.map(link => (
      <a href={link.href} class="block py-2 text-sm font-semibold text-muted-foreground hover:text-foreground">
        {link.label}
      </a>
    ))}
    <a
      href="https://github.com/jaimaann/LangHire"
      target="_blank"
      rel="noopener noreferrer"
      class="block py-2 text-sm font-semibold text-muted-foreground hover:text-foreground"
    >
      GitHub
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
