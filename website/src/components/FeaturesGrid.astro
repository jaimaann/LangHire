---
const features = [
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',
    title: 'Native Desktop App',
    description: 'Runs natively on macOS, Windows, and Linux. Lightweight Tauri shell with a modern React UI.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>',
    title: 'Job Collection',
    description: 'Searches LinkedIn for jobs matching your target titles and locations. Saves listings with URL, company, and description.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>',
    title: 'Automated Applications',
    description: 'AI agent fills forms, uploads your resume, answers screening questions, and submits. Runs multiple workers in parallel.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>',
    title: 'Tailored Resumes',
    description: 'Auto-customizes your resume for each job description. Highlights relevant experience and skills.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3 4 4.5 4.5 0 0 1-3-4"/><path d="M12 18v4"/></svg>',
    title: 'Self-Learning Memory',
    description: 'Stores per-ATS procedural knowledge. Lessons from one Workday site apply to all Workday sites.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>',
    title: 'Smart Q&A Reuse',
    description: 'Learns answers from previous applications and reuses them. Never re-answer the same screening question.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>',
    title: 'Multi-LLM Support',
    description: 'Works with OpenAI, Anthropic Claude, AWS Bedrock, or Ollama for fully local inference.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>',
    title: 'Dashboard & Analytics',
    description: 'Real-time stats, success rates, per-domain performance, and memory impact analysis.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>',
    title: 'CLI Tools',
    description: 'Power-user scripts for collection, application, memory management, and terminal analytics.',
  },
  {
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
    title: '100% Local',
    description: 'All data stored on your machine. Nothing leaves your computer except LLM API calls.',
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Everything You Need</h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        From job discovery to application submission, LangHire handles the entire workflow.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(feature => (
        <div class="card hover:shadow-md transition-shadow">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-primary/10 text-primary mb-4">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-base font-bold mb-2">{feature.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
