---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found - LangHire"
  description="The page you're looking for doesn't exist."
>
  <section class="max-w-2xl mx-auto px-6 py-32 text-center">
    <h1 class="text-6xl font-extrabold text-border mb-4">404</h1>
    <p class="text-xl text-muted-foreground mb-8">This page doesn't exist.</p>
    <a href="/" class="btn-primary">Back to Home</a>
  </section>
</BaseLayout>
